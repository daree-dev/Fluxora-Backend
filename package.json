{
  "name": "fluxora-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs",
    "test:src": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js",
    "test:all": "npm run test && npm run test:src",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.cjs --coverage",
    "test:coverage:src": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.js --coverage"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^14.6.1",
    "express": "^4.18.2",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
